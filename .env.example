# Rede / portas
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Credenciais e hosts
REDIS_HOST=localhost

# Ports expostas por serviços
INGESTOR_PORT=3000
NOTIFIER_PORT=3001
NGINX_PORT=80

# Chaves e URLs de terceiros
NASA_API_KEY=DEMO_KEY

# URLs de conveniência (podem ser construídas a partir das variáveis acima)
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://localhost
